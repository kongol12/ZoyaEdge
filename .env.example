# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_PRIMARY_SUPER_ADMIN_EMAIL: The email address of the primary super administrator.
VITE_PRIMARY_SUPER_ADMIN_EMAIL=your-email@example.com

# FIREBASE_SERVICE_ACCOUNT_KEY: Required for server-side Firebase operations on a custom project.
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate new private key"
# 3. Paste the entire JSON content here (or via the AI Studio Secrets UI)
FIREBASE_SERVICE_ACCOUNT_KEY=

# ARAKA Mobile Money API (RDC)
# Use Production Credentials
ARAKA_API_URL=https://api.araka-pay.com
ARAKA_CLIENT_ID=
ARAKA_CLIENT_SECRET=
ARAKA_EMAIL=
ARAKA_PASSWORD=
ARAKA_PAYMENT_PAGE_ID_USD=
ARAKA_PAYMENT_PAGE_ID_CDF=
ARAKA_CALLBACK_SECRET=
ALLOWED_ORIGINS=

# AI Engine Keys
GEMINI_API_KEY_FREE=
GEMINI_API_KEY_PAID=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
