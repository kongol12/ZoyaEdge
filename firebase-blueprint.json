{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and subscription status.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "agent", "admin"] },
        "subscription": { "type": "string", "enum": ["free", "pro", "premium"] },
        "subscriptionStatus": { "type": "string", "enum": ["active", "trialing", "expired", "suspended"] },
        "subscriptionCycle": { "type": "string", "enum": ["monthly", "yearly"] },
        "subscriptionEndDate": { "type": "string", "format": "date-time" },
        "aiCredits": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "onboarded": { "type": "boolean" }
      },
      "required": ["email", "createdAt"]
    },
    "Trade": {
      "title": "Trading Record",
      "description": "A single trade execution record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "pair": { "type": "string" },
        "direction": { "type": "string", "enum": ["buy", "sell"] },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "lotSize": { "type": "number" },
        "pnl": { "type": "number" },
        "strategy": { "type": "string" },
        "emotion": { "type": "string" },
        "session": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "ticket": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "pnl", "strategy", "date"]
    },
    "BrokerConnection": {
      "title": "Broker Sync Connection",
      "description": "Settings for MT4/MT5/Cloud sync.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "platform": { "type": "string", "enum": ["MT4", "MT5", "TradeLocker"] },
        "accountName": { "type": "string" },
        "syncKey": { "type": "string" },
        "webhookSecret": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "waiting", "error"] },
        "lastSync": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "platform", "accountName", "status"]
    },
    "AICoachCache": {
      "title": "AI Coach Cache",
      "description": "Cached result of an AI analysis to prevent redundant API calls.",
      "type": "object",
      "properties": {
        "tradesHash": { "type": "string" },
        "result": { "type": "object" },
        "cachedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AIReport": {
      "title": "AI Performance Report",
      "description": "An archived report generated by the AI Coach",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "mode": { "type": "string" },
        "metrics": { "type": "object" },
        "response": { "type": "object" }
      }
    },
    "Payment": {
      "title": "Subscription Payment",
      "description": "A record of a successful subscription payment",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "enum": ["USD", "CDF"] },
        "plan": { "type": "string", "enum": ["discovery", "pro", "premium"] },
        "cycle": { "type": "string", "enum": ["monthly", "yearly"] },
        "fee": { "type": "number", "description": "ZoyaPay transaction fee" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] },
        "method": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "country": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "currency", "plan", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Root user profile document."
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Collection of user trades."
    },
    "/users/{userId}/ai_coach/latest": {
      "schema": "AICoachCache",
      "description": "Latest AI analysis cache."
    },
    "/users/{userId}/ai_reports/{reportId}": {
      "schema": "AIReport",
      "description": "Archive of AI reports."
    },
    "/broker_connections/{connectionId}": {
      "schema": "BrokerConnection",
      "description": "Global broker connections for sync."
    },
    "/app_settings/global": {
      "schema": {
        "type": "object",
        "properties": {
          "exchangeRate": { "type": "number" },
          "arakaUsdPageId": { "type": "string" },
          "arakaCdfPageId": { "type": "string" },
          "discoveryMonthlyUSD": { "type": "number" },
          "discoveryYearlyUSD": { "type": "number" },
          "proMonthlyUSD": { "type": "number" },
          "proYearlyUSD": { "type": "number" },
          "premiumMonthlyUSD": { "type": "number" },
          "premiumYearlyUSD": { "type": "number" },
          "globalDiscount": { "type": "number" },
          "transactionFee": { "type": "number" }
        }
      },
      "description": "Global application settings."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Global subscription payments."
    }
  }
}
