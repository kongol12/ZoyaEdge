rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // ===============================================================
    // Section 1: Primitives & Identity
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isSuperAdmin() { return isSignedIn() && request.auth.token.email.toLowerCase() == 'kongolmandf@gmail.com'; }
    
    // Admin check via RBAC document
    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'agent']); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ===============================================================
    // Section 2: Validation Blueprints (The "Anti-Update-Gap")
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt is timestamp &&
             (!('role' in data) || data.role in ['user', 'agent', 'admin']) &&
             (!('subscription' in data) || data.subscription in ['free', 'pro', 'premium']) &&
             (!('aiCredits' in data) || (data.aiCredits is int && data.aiCredits >= 0));
    }

    function isValidTrade(data, userId) {
      return data.keys().hasAll(['userId', 'pnl', 'strategy', 'date', 'createdAt']) &&
             data.userId == userId &&
             data.pnl is number &&
             data.strategy is string && data.strategy.size() <= 100 &&
             data.date is timestamp &&
             data.createdAt is timestamp &&
             (!('pair' in data) || (data.pair is string && data.pair.size() <= 20)) &&
             (!('direction' in data) || data.direction in ['buy', 'sell']) &&
             (!('lotSize' in data) || data.lotSize is number);
    }

    function isValidBrokerConnection(data, userId) {
      return data.keys().hasAll(['userId', 'platform', 'accountName', 'status', 'createdAt']) &&
             data.userId == userId &&
             data.platform in ['MT4', 'MT5', 'TradeLocker'] &&
             data.accountName is string && data.accountName.size() <= 50 &&
             data.status in ['active', 'waiting', 'error'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Section 3: Domain Rules
    // ===============================================================

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == 'user' && 
                    (incoming().subscription == 'free' || incoming().subscription == 'pro'); 
      
      allow update: if (isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'tradingStyle', 'defaultRisk', 'defaultLotSize', 'currency', 'onboarded', 'calendarShowPnL', 'calendarShowTrades', 'initialBalance', 'updatedAt', 'onboarded', 'hasUsedTrial', 'subscription', 'subscriptionStatus', 'subscriptionEndDate', 'aiCredits'])) ||
                    isAdmin();

      // --- Sub-collections ---
      match /trades/{tradeId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTrade(incoming(), userId) && isValidId(tradeId);
        allow update: if isOwner(userId) && isValidTrade(incoming(), userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['pair', 'direction', 'entryPrice', 'exitPrice', 'lotSize', 'pnl', 'strategy', 'emotion', 'session', 'date', 'stopLoss', 'takeProfit', 'updatedAt']);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /ai_reports/{reportId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Server-side only (Admin SDK)
      }

      match /ai_coach/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      match /imports/{importId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /strategies/{strategyId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /notebook/{entryId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isOwner(userId);
      }
    }

    // --- Global Broker Connections ---
    match /broker_connections/{connectionId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidBrokerConnection(incoming(), request.auth.uid) && isValidId(connectionId);
      
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && 
                      isValidBrokerConnection(incoming(), request.auth.uid) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['accountName', 'brokerServer', 'brokerLogin', 'investorPassword', 'connectionType', 'updatedAt'])) ||
                    isAdmin();
      
      allow delete: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }

    match /payments/{paymentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /admin_notifications/{notifId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // --- Admin & Global Config ---
    match /app_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /bug_reports/{reportId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    match /global_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
