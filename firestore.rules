rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // ===============================================================
    // Section 1: Primitives & Identity
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isSuperAdmin() { 
      return isSignedIn() && 
             'email' in request.auth.token && 
             request.auth.token.email != null && 
             exists(/databases/$(database)/documents/app_settings/global) && 
             (request.auth.token.email.lower() == get(/databases/$(database)/documents/app_settings/global).data.primarySuperAdmin ||
              request.auth.token.email.lower() in get(/databases/$(database)/documents/app_settings/global).data.superAdmins);
    }
    
    function isPrimarySuperAdmin() {
      return isSignedIn() && 
             'email' in request.auth.token && 
             exists(/databases/$(database)/documents/app_settings/global) && 
             request.auth.token.email.lower() == get(/databases/$(database)/documents/app_settings/global).data.primarySuperAdmin;
    }
    
    // Admin check via RBAC document
    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'agent']); 
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ===============================================================
    // Section 2: Validation Blueprints (The "Anti-Update-Gap")
    // ===============================================================

    function isValidUser(data) {
      return (!('email' in data) || (data.email is string && data.email.size() <= 150)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 30)) &&
             (!('country' in data) || (data.country is string && data.country.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string)) &&
             (!('tradingStyle' in data) || data.tradingStyle is string) &&
             (!('experienceLevel' in data) || data.experienceLevel is string) &&
             (!('capitalSize' in data) || (data.capitalSize is string || data.capitalSize is number)) &&
             (!('assetTypes' in data) || data.assetTypes is list) &&
             (!('onboardingState' in data) || data.onboardingState is map) &&
             (!('onboarded' in data) || data.onboarded is bool) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('role' in data) || data.role in ['user', 'agent', 'admin']) &&
             (!('subscription' in data) || data.subscription is string) &&
             (!('subscriptionStatus' in data) || data.subscriptionStatus is string) &&
             (!('aiCredits' in data) || (data.aiCredits is int && data.aiCredits >= 0)) &&
             (!('createdBy' in data) || data.createdBy is string) &&
             (!('isEmergencyAdmin' in data) || data.isEmergencyAdmin is bool);
    }

    function isValidTrade(data, userId) {
      return data.keys().hasAll(['userId', 'pnl', 'strategy', 'date', 'createdAt']) &&
             data.userId == userId &&
             data.pnl is number &&
             data.strategy is string && data.strategy.size() <= 120 &&
             data.date is timestamp &&
             data.createdAt is timestamp &&
             (!('pair' in data) || (data.pair is string && data.pair.size() <= 50)) &&
             (!('direction' in data) || data.direction in ['buy', 'sell']) &&
             (!('lotSize' in data) || data.lotSize is number) &&
             (!('entryPrice' in data) || data.entryPrice is number) &&
             (!('exitPrice' in data) || data.exitPrice is number) &&
             (!('stopLoss' in data) || data.stopLoss is number) &&
             (!('takeProfit' in data) || data.takeProfit is number) &&
             (!('type' in data) || data.type in ['trade', 'deposit', 'withdrawal', 'adjustment']) &&
             (!('platform' in data) || data.platform is string) &&
             (!('isDemo' in data) || data.isDemo is bool) &&
             (!('hiddenByClient' in data) || data.hiddenByClient is bool) &&
             (!('assetType' in data) || data.assetType is string) &&
             (!('pips' in data) || data.pips is number) &&
             (!('risk' in data) || data.risk is number) &&
             (!('reward' in data) || data.reward is number) &&
             (!('rr' in data) || data.rr is number) &&
             (!('commission' in data) || data.commission is number) &&
             (!('swap' in data) || data.swap is number);
    }

    function isValidBrokerConnection(data, userId) {
      return data.keys().hasAll(['userId', 'platform', 'accountName', 'status', 'createdAt']) &&
             data.userId == userId &&
             data.platform in ['MT4', 'MT5', 'TradeLocker'] &&
             data.accountName is string && data.accountName.size() <= 50 &&
             data.status in ['active', 'waiting', 'error'] &&
             data.createdAt is timestamp;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['userId', 'amount', 'currency', 'plan', 'status', 'createdAt']) &&
             data.userId is string &&
             data.amount is number &&
             data.currency in ['USD', 'CDF'] &&
             data.plan in ['discovery', 'pro', 'premium', 'free', 'elite'] && // Allowing variations used in code
             data.status in ['completed', 'pending', 'failed'] &&
             data.createdAt is timestamp &&
             (!('fee' in data) || data.fee is number);
    }

    // ===============================================================
    // Section 3: Domain Rules
    // ===============================================================

    // --- Sub-collections (with collectionGroup for admins) ---
    match /{path=**}/trades/{tradeId} {
      allow read: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                    incoming().keys().hasAll(['email', 'createdAt']) &&
                    isValidUser(incoming()) && 
                    incoming().role == 'user' && 
                    (incoming().subscription in ['free', 'discovery', 'pro']); 
      
      allow update: if (isOwner(userId) && 
                    isValidUser(incoming()) &&
                    !incoming().diff(existing()).affectedKeys().hasAny([
                      'role', 'subscription', 'createdAt', 'email', 'subscriptionEndDate', 'subscriptionStatus', 'aiCredits', 'createdBy', 'isEmergencyAdmin'
                    ])) ||
              isSuperAdmin() ||
              (isAdmin() && !('role' in incoming() || 'isEmergencyAdmin' in incoming()));
      match /trades/{tradeId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTrade(incoming(), userId) && isValidId(tradeId);
        allow update: if isOwner(userId) && isValidTrade(incoming(), userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['pair', 'direction', 'entryPrice', 'exitPrice', 'lotSize', 'pnl', 'strategy', 'emotion', 'session', 'date', 'stopLoss', 'takeProfit', 'updatedAt', 'pips', 'risk', 'reward', 'rr', 'assetType', 'hiddenByClient']);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /ai_reports/{reportId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if false; // Server-side only (Admin SDK)
      }

      match /ai_coach/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }

      match /imports/{importId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /strategies/{strategyId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /notebook/{entryId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isOwner(userId);
      }
    }

    // --- Global Broker Connections ---
    match /broker_connections/{connectionId} {
      allow read: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidBrokerConnection(incoming(), request.auth.uid) && isValidId(connectionId);
      
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && 
                      isValidBrokerConnection(incoming(), request.auth.uid) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['accountName', 'brokerServer', 'brokerLogin', 'investorPassword', 'connectionType', 'updatedAt'])) ||
                    isAdmin();
      
      allow delete: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }

    match /payments/{paymentId} {
      allow list: if isAdmin();
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidPayment(incoming());
      allow update, delete: if isAdmin();
    }

    match /admin_notifications/{notifId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Admin & Global Config ---
    match /app_settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /bug_reports/{reportId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    match /global_notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    function isValidSystemLog(data) {
      return data.keys().hasAll(['type', 'severity', 'message', 'createdAt']) &&
             data.type in ['auth', 'navigation', 'action', 'system', 'security'] &&
             data.severity in ['info', 'warning', 'error', 'critical'] &&
             data.message is string && data.message.size() <= 1000 &&
             data.createdAt == request.time &&
             (!('userId' in data) || data.userId is string) &&
             (!('userEmail' in data) || data.userEmail is string) &&
             (!('path' in data) || data.path is string) &&
             (!('ip' in data) || data.ip is string) &&
             (!('metadata' in data) || data.metadata is map);
    }

    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isValidSystemLog(incoming()) && isValidId(logId);
    }

    match /user_activity/{actId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() &&
        incoming().keys().hasAll(['userId', 'type', 'createdAt']) &&
        incoming().userId == request.auth.uid &&
        incoming().type is string &&
        (!('metadata' in incoming()) || incoming().metadata is map);
    }
  }
}
